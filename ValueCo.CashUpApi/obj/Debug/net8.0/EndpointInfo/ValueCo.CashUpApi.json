{
  "openapi": "3.0.1",
  "info": {
    "title": "ValueCo.CashUpApi",
    "version": "1.0"
  },
  "paths": {
    "/api/cashup/{storeCode}/{year}/{month}": {
      "get": {
        "tags": [
          "CashUp"
        ],
        "parameters": [
          {
            "name": "storeCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "month",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/cashup/{storeCode}/{year}/{month}/{day}": {
      "get": {
        "tags": [
          "CashUp"
        ],
        "parameters": [
          {
            "name": "storeCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "month",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "day",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/cashup": {
      "post": {
        "tags": [
          "CashUp"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CashUpSubmitDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CashUpSubmitDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CashUpSubmitDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/stores": {
      "get": {
        "tags": [
          "Stores"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
